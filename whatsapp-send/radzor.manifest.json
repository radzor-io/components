{
  "radzor": "1.0.0",
  "name": "@radzor/whatsapp-send",
  "version": "0.1.0",
  "description": "Send WhatsApp messages via the Meta Cloud API. Supports text, template, and media messages with delivery and read receipt tracking.",
  "languages": [
    "typescript",
    "python"
  ],
  "category": "messaging",
  "runtime": "server",
  "tags": [
    "whatsapp",
    "messaging",
    "sms",
    "cloud-api",
    "meta",
    "notifications"
  ],
  "inputs": [
    {
      "name": "accessToken",
      "type": "string",
      "description": "Meta Cloud API access token.",
      "required": true,
      "envVar": "WHATSAPP_ACCESS_TOKEN"
    },
    {
      "name": "phoneNumberId",
      "type": "string",
      "description": "WhatsApp Business phone number ID.",
      "required": true,
      "envVar": "WHATSAPP_PHONE_NUMBER_ID"
    },
    {
      "name": "apiVersion",
      "type": "string",
      "description": "Graph API version (default: v18.0).",
      "required": false,
      "default": "v18.0"
    }
  ],
  "outputs": [
    {
      "name": "sendResult",
      "type": "{ messageId: string; recipientPhone: string }",
      "description": "Result of a send operation.",
      "fields": [
        {
          "name": "messageId",
          "type": "string",
          "description": "WhatsApp message ID (wamid)."
        },
        {
          "name": "recipientPhone",
          "type": "string",
          "description": "Recipient phone number."
        }
      ]
    }
  ],
  "events": [
    {
      "name": "onMessageDelivered",
      "payload": {
        "messageId": "string",
        "recipientPhone": "string",
        "timestamp": "string"
      },
      "description": "Fired when a message is delivered to the recipient's device."
    },
    {
      "name": "onMessageRead",
      "payload": {
        "messageId": "string",
        "recipientPhone": "string",
        "timestamp": "string"
      },
      "description": "Fired when the recipient reads the message."
    }
  ],
  "actions": [
    {
      "name": "sendText",
      "params": [
        {
          "name": "to",
          "type": "string",
          "description": "Recipient phone number in international format (e.g. 14155552671)."
        },
        {
          "name": "body",
          "type": "string",
          "description": "Message text body."
        },
        {
          "name": "previewUrl",
          "type": "boolean",
          "description": "Whether to show URL previews.",
          "required": false
        }
      ],
      "returns": "Promise<{ messageId: string }>",
      "description": "Send a plain text message."
    },
    {
      "name": "sendTemplate",
      "params": [
        {
          "name": "to",
          "type": "string",
          "description": "Recipient phone number."
        },
        {
          "name": "templateName",
          "type": "string",
          "description": "Approved template name."
        },
        {
          "name": "languageCode",
          "type": "string",
          "description": "Template language code (e.g. en_US)."
        },
        {
          "name": "components",
          "type": "object[]",
          "description": "Template component parameters (header, body, button variables).",
          "required": false
        }
      ],
      "returns": "Promise<{ messageId: string }>",
      "description": "Send a pre-approved template message."
    },
    {
      "name": "sendMedia",
      "params": [
        {
          "name": "to",
          "type": "string",
          "description": "Recipient phone number."
        },
        {
          "name": "mediaType",
          "type": "\"image\" | \"video\" | \"audio\" | \"document\"",
          "description": "Type of media to send."
        },
        {
          "name": "mediaUrl",
          "type": "string",
          "description": "Public URL of the media file.",
          "required": false
        },
        {
          "name": "mediaId",
          "type": "string",
          "description": "Previously uploaded media ID.",
          "required": false
        },
        {
          "name": "caption",
          "type": "string",
          "description": "Optional caption for image/video/document.",
          "required": false
        }
      ],
      "returns": "Promise<{ messageId: string }>",
      "description": "Send a media message (image, video, audio, or document)."
    },
    {
      "name": "markAsRead",
      "params": [
        {
          "name": "messageId",
          "type": "string",
          "description": "WhatsApp message ID to mark as read."
        }
      ],
      "returns": "Promise<boolean>",
      "description": "Mark an incoming message as read (sends blue ticks)."
    }
  ],
  "dependencies": {
    "packages": {},
    "radzor": []
  },
  "composability": {
    "connectsTo": [
      {
        "event": "onMessageDelivered",
        "description": "Track WhatsApp message delivery for analytics",
        "compatibleWith": [
          "@radzor/event-tracker.action.track.eventName",
          "@radzor/log-aggregator.action.info.message"
        ]
      },
      {
        "output": "sendResult",
        "compatibleWith": [
          "@radzor/log-aggregator.action.info.message"
        ],
        "mapField": "messageId"
      }
    ]
  },
  "llm": {
    "integrationPrompt": "llm/integration.md",
    "usageExamples": "llm/examples.md",
    "constraints": "Requires a Meta Business account with WhatsApp API access. Template messages must be pre-approved by Meta. Phone numbers must include country code without + prefix. Media URLs must be publicly accessible HTTPS URLs."
  }
}

{
  "radzor": "1.0.0",
  "name": "@radzor/image-transform",
  "version": "0.1.0",
  "description": "High-performance image transformation using Sharp. Resize, crop, convert formats, apply watermarks, strip metadata, and optimize for web. Supports JPEG, PNG, WebP, AVIF, GIF, and SVG inputs.",
  "languages": ["typescript"],
  "category": "media",
  "tags": ["image", "resize", "compress", "sharp", "webp", "avif", "crop", "watermark", "optimize"],
  "inputs": [
    {
      "name": "quality",
      "type": "number",
      "default": 80,
      "description": "Output quality for lossy formats (1-100). Applies to JPEG, WebP, AVIF.",
      "required": false
    },
    {
      "name": "defaultFormat",
      "type": "'jpeg' | 'png' | 'webp' | 'avif'",
      "default": "webp",
      "description": "Default output format when not specified per operation.",
      "required": false
    },
    {
      "name": "stripMetadata",
      "type": "boolean",
      "default": true,
      "description": "Remove EXIF, GPS, and ICC metadata from output.",
      "required": false
    },
    {
      "name": "progressive",
      "type": "boolean",
      "default": true,
      "description": "Use progressive (interlaced) encoding for JPEG/PNG.",
      "required": false
    }
  ],
  "outputs": [
    {
      "name": "imageBuffer",
      "type": "Buffer",
      "description": "Transformed image as raw bytes."
    },
    {
      "name": "metadata",
      "type": "ImageMetadata",
      "description": "Output image metadata: width, height, format, size."
    }
  ],
  "events": [
    {
      "name": "onTransformed",
      "payload": { "format": "string", "width": "number", "height": "number", "sizeBytes": "number" },
      "description": "Fired when a transformation completes successfully."
    },
    {
      "name": "onError",
      "payload": { "code": "string", "message": "string", "operation": "string" },
      "description": "Fired when a transformation fails."
    }
  ],
  "actions": [
    {
      "name": "resize",
      "params": [
        { "name": "input", "type": "Buffer | string", "description": "Input image as Buffer or file path." },
        { "name": "width", "type": "number", "description": "Target width in pixels.", "required": false },
        { "name": "height", "type": "number", "description": "Target height in pixels.", "required": false },
        { "name": "fit", "type": "'cover' | 'contain' | 'fill' | 'inside' | 'outside'", "description": "Resize strategy.", "required": false }
      ],
      "returns": "Promise<Buffer>",
      "description": "Resize an image. Preserves aspect ratio by default (fit=inside)."
    },
    {
      "name": "crop",
      "params": [
        { "name": "input", "type": "Buffer | string", "description": "Input image." },
        { "name": "width", "type": "number", "description": "Crop width." },
        { "name": "height", "type": "number", "description": "Crop height." },
        { "name": "left", "type": "number", "description": "Left offset.", "required": false },
        { "name": "top", "type": "number", "description": "Top offset.", "required": false }
      ],
      "returns": "Promise<Buffer>",
      "description": "Crop a region from an image."
    },
    {
      "name": "convert",
      "params": [
        { "name": "input", "type": "Buffer | string", "description": "Input image." },
        { "name": "format", "type": "'jpeg' | 'png' | 'webp' | 'avif'", "description": "Target format." },
        { "name": "quality", "type": "number", "description": "Output quality override (1-100).", "required": false }
      ],
      "returns": "Promise<Buffer>",
      "description": "Convert an image to a different format."
    },
    {
      "name": "watermark",
      "params": [
        { "name": "input", "type": "Buffer | string", "description": "Base image." },
        { "name": "overlay", "type": "Buffer | string", "description": "Watermark image to composite." },
        { "name": "gravity", "type": "'southeast' | 'south' | 'southwest' | 'east' | 'center' | 'west' | 'northeast' | 'north' | 'northwest'", "description": "Watermark position.", "required": false }
      ],
      "returns": "Promise<Buffer>",
      "description": "Add a watermark overlay to an image."
    },
    {
      "name": "getMetadata",
      "params": [
        { "name": "input", "type": "Buffer | string", "description": "Input image." }
      ],
      "returns": "Promise<ImageMetadata>",
      "description": "Read image metadata without transformation."
    }
  ],
  "dependencies": {
    "packages": {
      "sharp": "^0.33.0"
    },
    "radzor": ["@radzor/file-upload"]
  },
  "composability": {},
  "llm": {
    "integrationPrompt": "llm/integration.md",
    "usageExamples": "llm/examples.md",
    "constraints": "Sharp requires native bindings — prebuilt binaries are available for common platforms. Not compatible with edge runtimes. In Docker, install libvips or use the sharp Docker image. Width and height are both optional in resize; omit one to scale proportionally."
  }
}

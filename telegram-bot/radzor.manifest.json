{
  "radzor": "1.0.0",
  "name": "@radzor/telegram-bot",
  "version": "0.1.0",
  "description": "Telegram bot component using the Bot API. Send messages, photos, reply keyboards, and inline keyboards.",
  "languages": ["typescript", "python"],
  "category": "chat",
  "tags": ["telegram", "bot", "chat", "messaging", "social"],
  "inputs": [
    {
      "name": "botToken",
      "type": "string",
      "description": "Telegram Bot API token from @BotFather.",
      "required": true
    }
  ],
  "outputs": [
    {
      "name": "messageResult",
      "type": "{ messageId: number; chatId: number }",
      "description": "Sent message ID and chat ID."
    }
  ],
  "events": [
    {
      "name": "onMessageSent",
      "payload": { "messageId": "number", "chatId": "string" },
      "description": "Fired when a message is successfully sent."
    },
    {
      "name": "onError",
      "payload": { "code": "string", "message": "string" },
      "description": "Fired on API error."
    }
  ],
  "actions": [
    {
      "name": "sendMessage",
      "params": [
        { "name": "chatId", "type": "number | string", "description": "Target chat ID or @username." },
        { "name": "text", "type": "string", "description": "Message text (supports Markdown or HTML)." },
        { "name": "parseMode", "type": "'Markdown' | 'HTML'", "description": "Text formatting mode.", "required": false }
      ],
      "returns": "Promise<{ messageId: number; chatId: number }>",
      "description": "Send a text message to a chat."
    },
    {
      "name": "sendPhoto",
      "params": [
        { "name": "chatId", "type": "number | string", "description": "Target chat ID or @username." },
        { "name": "photo", "type": "Buffer | string", "description": "Photo as Buffer or public URL." },
        { "name": "caption", "type": "string", "description": "Optional caption text.", "required": false }
      ],
      "returns": "Promise<{ messageId: number; chatId: number }>",
      "description": "Send a photo to a chat."
    },
    {
      "name": "sendReplyKeyboard",
      "params": [
        { "name": "chatId", "type": "number | string", "description": "Target chat ID." },
        { "name": "text", "type": "string", "description": "Message text." },
        { "name": "keyboard", "type": "string[][]", "description": "2D array of button labels." }
      ],
      "returns": "Promise<{ messageId: number; chatId: number }>",
      "description": "Send a message with a reply keyboard."
    },
    {
      "name": "sendInlineKeyboard",
      "params": [
        { "name": "chatId", "type": "number | string", "description": "Target chat ID." },
        { "name": "text", "type": "string", "description": "Message text." },
        { "name": "keyboard", "type": "Array<Array<{ text: string; callbackData: string }>>", "description": "Inline keyboard button rows." }
      ],
      "returns": "Promise<{ messageId: number; chatId: number }>",
      "description": "Send a message with inline keyboard buttons."
    }
  ],
  "dependencies": { "packages": {} },
  "composability": {}
}

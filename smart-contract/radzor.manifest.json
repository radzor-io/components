{
  "radzor": "1.0.0",
  "name": "@radzor/smart-contract",
  "version": "0.1.0",
  "description": "Interact with EVM smart contracts via JSON-RPC. Read state, call functions, and send transactions.",
  "languages": [
    "typescript",
    "python"
  ],
  "category": "web3",
  "runtime": "server",
  "tags": [
    "smart-contract",
    "ethereum",
    "evm",
    "solidity",
    "web3",
    "blockchain"
  ],
  "inputs": [
    {
      "name": "rpcUrl",
      "type": "string",
      "description": "JSON-RPC endpoint URL (e.g. Infura, Alchemy, or local node).",
      "required": true
    },
    {
      "name": "contractAddress",
      "type": "string",
      "description": "Deployed contract address (0x...).",
      "required": true
    },
    {
      "name": "abi",
      "type": "object[]",
      "description": "Contract ABI as JSON array.",
      "required": true
    }
  ],
  "outputs": [
    {
      "name": "callResult",
      "type": "unknown",
      "description": "Decoded return value from the contract call."
    }
  ],
  "events": [
    {
      "name": "onCallResult",
      "payload": {
        "method": "string",
        "result": "string"
      },
      "description": "Fired on successful contract read call."
    },
    {
      "name": "onError",
      "payload": {
        "code": "string",
        "message": "string",
        "method": "string"
      },
      "description": "Fired on JSON-RPC or ABI error."
    }
  ],
  "actions": [
    {
      "name": "call",
      "params": [
        {
          "name": "method",
          "type": "string",
          "description": "Contract function name to call."
        },
        {
          "name": "args",
          "type": "unknown[]",
          "description": "Arguments for the function.",
          "required": false
        }
      ],
      "returns": "Promise<unknown>",
      "description": "Read-only call to a view/pure contract function."
    },
    {
      "name": "encodeFunctionData",
      "params": [
        {
          "name": "method",
          "type": "string",
          "description": "Function name."
        },
        {
          "name": "args",
          "type": "unknown[]",
          "description": "Function arguments."
        }
      ],
      "returns": "string",
      "description": "ABI-encode a function call for use in a raw transaction."
    },
    {
      "name": "decodeFunctionResult",
      "params": [
        {
          "name": "method",
          "type": "string",
          "description": "Function name."
        },
        {
          "name": "data",
          "type": "string",
          "description": "Hex-encoded return data from the call."
        }
      ],
      "returns": "unknown[]",
      "description": "ABI-decode return data from a contract call."
    }
  ],
  "dependencies": {
    "packages": {}
  },
  "composability": {
    "connectsTo": [
      {
        "event": "onCallResult",
        "description": "Log smart contract call results",
        "compatibleWith": [
          "@radzor/event-tracker.action.track.eventName",
          "@radzor/log-aggregator.action.info.message"
        ]
      },
      {
        "event": "onError",
        "description": "Track smart contract errors",
        "compatibleWith": [
          "@radzor/error-tracker.action.captureMessage.message",
          "@radzor/notification-hub.action.send.body"
        ]
      }
    ]
  },
  "llm": {
    "integrationPrompt": "llm/integration.md",
    "usageExamples": "llm/examples.md",
    "constraints": "Requires an Ethereum JSON-RPC endpoint (Infura, Alchemy, or local node). ABI must match the deployed contract. Sending transactions requires a funded private key."
  }
}

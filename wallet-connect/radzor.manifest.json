{
  "radzor": "1.0.0",
  "name": "@radzor/wallet-connect",
  "version": "0.1.0",
  "description": "Connect to Ethereum wallets (MetaMask, WalletConnect) for Web3 dApps. Client-side only.",
  "languages": ["typescript"],
  "category": "web3",
  "tags": ["wallet", "ethereum", "web3", "metamask", "crypto", "blockchain"],
  "inputs": [
    {
      "name": "chainId",
      "type": "number",
      "description": "Target chain ID (default: 1 for Ethereum mainnet)",
      "required": false
    },
    {
      "name": "rpcUrl",
      "type": "string",
      "description": "JSON-RPC endpoint URL",
      "required": false
    }
  ],
  "outputs": [],
  "events": [
    { "name": "onConnected", "description": "Fired when wallet is connected" },
    { "name": "onDisconnected", "description": "Fired when wallet is disconnected" },
    { "name": "onChainChanged", "description": "Fired when chain changes" },
    { "name": "onError", "description": "Fired on error" }
  ],
  "actions": [
    { "name": "connect", "description": "Request wallet connection" },
    { "name": "disconnect", "description": "Disconnect wallet" },
    { "name": "getBalance", "description": "Get ETH balance for connected address" },
    { "name": "sendTransaction", "description": "Send an ETH transaction" },
    { "name": "signMessage", "description": "Sign a message with the connected wallet" }
  ],
  "dependencies": { "packages": {} },
  "composability": {}
}

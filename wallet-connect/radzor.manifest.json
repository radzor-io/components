{
  "name": "wallet-connect",
  "version": "0.1.0",
  "description": "Connect to Ethereum wallets (MetaMask, WalletConnect) for Web3 dApps. Client-side only.",
  "category": "security",
  "tags": [
    "wallet",
    "ethereum",
    "web3",
    "metamask",
    "crypto",
    "blockchain"
  ],
  "inputs": {
    "chainId": {
      "type": "number",
      "required": false,
      "description": "Target chain ID (default: 1 for Ethereum mainnet)"
    },
    "rpcUrl": {
      "type": "string",
      "required": false,
      "description": "JSON-RPC endpoint URL"
    }
  },
  "outputs": {
    "onConnected": {
      "type": "event",
      "description": "Fired when wallet is connected"
    },
    "onDisconnected": {
      "type": "event",
      "description": "Fired when wallet is disconnected"
    },
    "onChainChanged": {
      "type": "event",
      "description": "Fired when chain changes"
    },
    "onError": {
      "type": "event",
      "description": "Fired on error"
    }
  },
  "actions": {
    "connect": {
      "description": "Request wallet connection"
    },
    "disconnect": {
      "description": "Disconnect wallet"
    },
    "getBalance": {
      "description": "Get ETH balance for connected address"
    },
    "sendTransaction": {
      "description": "Send an ETH transaction"
    },
    "signMessage": {
      "description": "Sign a message with the connected wallet"
    }
  },
  "languages": [
    "typescript"
  ],
  "composesWith": [
    "smart-contract"
  ]
}

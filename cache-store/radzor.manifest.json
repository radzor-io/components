{
  "radzor": "1.0.0",
  "name": "@radzor/cache-store",
  "version": "0.1.0",
  "description": "In-memory cache with TTL, LRU eviction, and namespace support. No external dependencies.",
  "languages": [
    "typescript",
    "python"
  ],
  "category": "data",
  "runtime": "server",
  "tags": [
    "cache",
    "store",
    "ttl",
    "lru",
    "memory",
    "performance"
  ],
  "inputs": [
    {
      "name": "maxSize",
      "type": "number",
      "description": "Maximum number of entries (default: 1000)",
      "required": false
    },
    {
      "name": "defaultTtl",
      "type": "number",
      "description": "Default TTL in milliseconds (default: 0 = no expiry)",
      "required": false
    }
  ],
  "outputs": [
    {
      "name": "cacheStats",
      "type": "{ size: number; hits: number; misses: number }",
      "description": "Current cache statistics."
    }
  ],
  "events": [
    {
      "name": "onHit",
      "payload": {
        "key": "string"
      },
      "description": "Fired on cache hit."
    },
    {
      "name": "onMiss",
      "payload": {
        "key": "string"
      },
      "description": "Fired on cache miss."
    },
    {
      "name": "onEvicted",
      "payload": {
        "key": "string",
        "reason": "string"
      },
      "description": "Fired when an entry is evicted (TTL expired or LRU)."
    },
    {
      "name": "onError",
      "payload": {
        "code": "string",
        "message": "string"
      },
      "description": "Fired on error."
    }
  ],
  "actions": [
    {
      "name": "get",
      "params": [
        {
          "name": "key",
          "type": "string",
          "description": "Cache key."
        }
      ],
      "returns": "T | undefined",
      "description": "Get a value from cache. Returns undefined on miss."
    },
    {
      "name": "set",
      "params": [
        {
          "name": "key",
          "type": "string",
          "description": "Cache key."
        },
        {
          "name": "value",
          "type": "T",
          "description": "Value to store."
        },
        {
          "name": "ttl",
          "type": "number",
          "description": "TTL in milliseconds. Overrides defaultTtl.",
          "required": false
        }
      ],
      "returns": "void",
      "description": "Set a value in cache with optional TTL."
    },
    {
      "name": "delete",
      "params": [
        {
          "name": "key",
          "type": "string",
          "description": "Cache key to delete."
        }
      ],
      "returns": "boolean",
      "description": "Delete a cache entry. Returns true if it existed."
    },
    {
      "name": "clear",
      "params": [],
      "returns": "void",
      "description": "Clear all entries in the cache."
    }
  ],
  "dependencies": {
    "packages": {}
  },
  "composability": {
    "connectsTo": [
      {
        "event": "onEvicted",
        "description": "Log cache evictions for capacity monitoring",
        "compatibleWith": [
          "@radzor/log-aggregator.action.info.message",
          "@radzor/event-tracker.action.track.eventName"
        ]
      },
      {
        "event": "onMiss",
        "description": "Track cache misses for optimization",
        "compatibleWith": [
          "@radzor/event-tracker.action.track.eventName"
        ]
      }
    ]
  },
  "llm": {
    "integrationPrompt": "llm/integration.md",
    "usageExamples": "llm/examples.md",
    "constraints": "No external dependencies. In-memory only — cache is lost on process restart. Set maxSize to prevent memory leaks. TTL is in milliseconds."
  }
}

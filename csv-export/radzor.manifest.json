{
  "radzor": "1.0.0",
  "name": "@radzor/csv-export",
  "version": "0.1.0",
  "description": "Generate and parse CSV files from data arrays. Supports custom delimiters, headers, and streaming.",
  "languages": ["typescript", "python"],
  "category": "data",
  "tags": ["csv", "export", "import", "parse", "data", "spreadsheet"],
  "inputs": [
    {
      "name": "delimiter",
      "type": "string",
      "description": "Column delimiter (default: ',')",
      "required": false
    },
    {
      "name": "includeHeaders",
      "type": "boolean",
      "description": "Include header row (default: true)",
      "required": false
    }
  ],
  "outputs": [],
  "events": [
    { "name": "onGenerated", "description": "Fired when CSV is generated" },
    { "name": "onError", "description": "Fired on error" }
  ],
  "actions": [
    { "name": "generate", "description": "Generate CSV string from data array" },
    { "name": "parse", "description": "Parse CSV string into data array" },
    { "name": "toFile", "description": "Write CSV to a file" }
  ],
  "dependencies": { "packages": {} },
  "composability": {}
}

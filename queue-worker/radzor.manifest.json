{
  "radzor": "1.0.0",
  "name": "@radzor/queue-worker",
  "version": "0.1.0",
  "description": "In-memory job queue with workers, retries, and dead-letter handling. No external dependencies.",
  "languages": [
    "typescript",
    "python"
  ],
  "category": "automation",
  "runtime": "server",
  "tags": [
    "queue",
    "worker",
    "jobs",
    "background",
    "async",
    "task"
  ],
  "inputs": [
    {
      "name": "concurrency",
      "type": "number",
      "description": "Max concurrent workers (default: 1)",
      "required": false
    },
    {
      "name": "maxRetries",
      "type": "number",
      "description": "Max retry attempts per job (default: 3)",
      "required": false
    },
    {
      "name": "retryDelay",
      "type": "number",
      "description": "Delay between retries in ms (default: 1000)",
      "required": false
    }
  ],
  "outputs": [
    {
      "name": "jobResult",
      "type": "{ jobId: string; status: 'completed' | 'failed'; result?: unknown; error?: string }",
      "description": "Result of a completed or failed job."
    }
  ],
  "events": [
    {
      "name": "onJobComplete",
      "payload": {
        "jobId": "string",
        "name": "string",
        "durationMs": "number"
      },
      "description": "Fired when a job completes successfully."
    },
    {
      "name": "onJobFailed",
      "payload": {
        "jobId": "string",
        "name": "string",
        "error": "string",
        "attempts": "number"
      },
      "description": "Fired when a job fails after all retries."
    },
    {
      "name": "onError",
      "payload": {
        "code": "string",
        "message": "string"
      },
      "description": "Fired on queue error."
    }
  ],
  "actions": [
    {
      "name": "addJob",
      "params": [
        {
          "name": "name",
          "type": "string",
          "description": "Job queue name."
        },
        {
          "name": "payload",
          "type": "unknown",
          "description": "Serializable job data."
        }
      ],
      "returns": "string",
      "description": "Add a job to the queue. Returns the job ID."
    },
    {
      "name": "process",
      "params": [
        {
          "name": "name",
          "type": "string",
          "description": "Queue name to process."
        },
        {
          "name": "handler",
          "type": "(payload: unknown) => Promise<unknown>",
          "description": "Async handler function."
        }
      ],
      "returns": "void",
      "description": "Register a worker handler for a queue. Call once at startup."
    },
    {
      "name": "start",
      "params": [],
      "returns": "void",
      "description": "Start processing queued jobs."
    },
    {
      "name": "stop",
      "params": [],
      "returns": "void",
      "description": "Stop processing and drain the queue gracefully."
    }
  ],
  "dependencies": {
    "packages": {}
  },
  "composability": {},
  "llm": {
    "integrationPrompt": "llm/integration.md",
    "usageExamples": "llm/examples.md",
    "constraints": "No external dependencies. In-memory only \u2014 jobs are lost on process restart. For persistent queues use Redis or a dedicated message broker. Concurrency controls parallel workers."
  }
}

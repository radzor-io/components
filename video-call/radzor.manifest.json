{
  "name": "video-call",
  "version": "0.1.0",
  "description": "WebRTC-based peer-to-peer video calling. Manage local/remote streams, signaling, and call lifecycle.",
  "category": "chat",
  "tags": ["video", "call", "webrtc", "peer-to-peer", "streaming", "media"],
  "inputs": {
    "iceServers": {
      "type": "array",
      "required": false,
      "description": "ICE server configuration (default: Google STUN)"
    },
    "signalingUrl": {
      "type": "string",
      "required": false,
      "description": "WebSocket signaling server URL"
    }
  },
  "outputs": {
    "onLocalStream": {
      "type": "event",
      "description": "Fired when local media stream is ready"
    },
    "onRemoteStream": {
      "type": "event",
      "description": "Fired when remote stream is received"
    },
    "onCallEnded": {
      "type": "event",
      "description": "Fired when call ends"
    },
    "onError": {
      "type": "event",
      "description": "Fired on error"
    }
  },
  "actions": {
    "startCall": {
      "description": "Initiate a video call (create offer)"
    },
    "answerCall": {
      "description": "Answer an incoming call (create answer)"
    },
    "endCall": {
      "description": "End the current call"
    },
    "toggleAudio": {
      "description": "Mute/unmute audio"
    },
    "toggleVideo": {
      "description": "Enable/disable video"
    }
  },
  "languages": ["typescript"]
}
